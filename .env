# ---- App ----
PORT=3000
NODE_ENV=development
SESSION_SECRET=change_this_to_a_long_random_string

# ---- MySQL Database ----
# On Railway, add the "MySQL" plugin, then copy its connection variables here
# (Railway auto-injects MYSQL* vars when using the reference variables below).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=employee_directory

# Alternative: a single connection URL (Railway provides MYSQL_URL / MYSQL_PUBLIC_URL)
# If DATABASE_URL is set, it takes priority over the DB_* fields above.
DATABASE_URL=

# ---- Default Admin Account (created automatically on first boot if missing) ----
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@12345
