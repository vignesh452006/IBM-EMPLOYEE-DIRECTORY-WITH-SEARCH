# Server
PORT=5000

# Allowed origin(s) for CORS - your Vercel frontend URL(s), comma separated
# Example: https://my-employee-directory.vercel.app,http://localhost:5500
CORS_ORIGIN=*

# ---- Database connection (Turso / libSQL / SQLite) ----
# Get these from the Turso CLI after creating your database:
#   turso db create employee-directory
#   turso db show employee-directory --url          -> TURSO_DATABASE_URL
#   turso db tokens create employee-directory        -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-db-name-yourusername.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Local development: if you leave TURSO_DATABASE_URL unset, the app
# automatically falls back to a local SQLite file (local.db) - no Turso
# account needed to run and test locally.

# Optional: seed the database with sample rows on first boot if the
# employees table is empty (true/false)
SEED_SAMPLE_DATA=true
