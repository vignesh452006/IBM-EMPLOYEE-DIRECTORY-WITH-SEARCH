<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head') %>
</head>
<body>
<div class="toast-stack" id="toastStack">
  <%- include('partials/flash') %>
</div>

<%- include('partials/navbar') %>

<section class="hero">
  <div class="container hero-inner">
    <h1 class="hero-title fade-up">Find anyone on the team, <span class="accent">instantly</span>.</h1>
    <p class="hero-sub fade-up delay-1">Search by name, role, or skill. Browse departments. Reach out in one click.</p>

    <form class="search-bar fade-up delay-2" id="searchForm">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 5L20.49 19zm-6 0A4.5 4.5 0 1 1 14 9.5A4.5 4.5 0 0 1 9.5 14"/></svg>
        <input type="text" name="q" id="searchInput" placeholder="Search by name, role, or skill..." value="<%= search %>" autocomplete="off">
      </div>

      <select name="department" id="departmentFilter" class="filter-select">
        <option value="">All Departments</option>
        <% departments.forEach(function(d) { %>
          <option value="<%= d.id %>" <%= (String(department) === String(d.id)) ? 'selected' : '' %>><%= d.name %></option>
        <% }) %>
      </select>

      <select name="status" id="statusFilter" class="filter-select">
        <option value="">Any Status</option>
        <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="on_leave" <%= status === 'on_leave' ? 'selected' : '' %>>On Leave</option>
        <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
      </select>

      <select name="sort" id="sortSelect" class="filter-select">
        <option value="name_asc" <%= sort === 'name_asc' ? 'selected' : '' %>>Name A–Z</option>
        <option value="name_desc" <%= sort === 'name_desc' ? 'selected' : '' %>>Name Z–A</option>
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest Hires</option>
        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Longest Tenure</option>
      </select>
    </form>

    <div class="view-toggle fade-up delay-2">
      <button class="view-btn <%= view === 'grid' ? 'active' : '' %>" data-view="grid" aria-label="Grid view">
        <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M4 4h7v7H4zm9 0h7v7h-7zm-9 9h7v7H4zm9 0h7v7h-7z"/></svg>
      </button>
      <button class="view-btn <%= view === 'list' ? 'active' : '' %>" data-view="list" aria-label="List view">
        <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M4 5h16v2H4zm0 6h16v2H4zm0 6h16v2H4z"/></svg>
      </button>
    </div>
  </div>
</section>

<main class="container directory-main">
  <div class="directory-meta">
    <span id="resultCount"><strong><%= total %></strong> team member<%= total === 1 ? '' : 's' %> found</span>
  </div>

  <div id="employeeGrid" class="employee-grid <%= view === 'list' ? 'list-mode' : '' %>" data-view="<%= view %>">
    <% if (employees.length === 0) { %>
      <div class="empty-state fade-up">
        <div class="empty-icon">🔍</div>
        <h3>No employees match your search</h3>
        <p>Try adjusting your filters or search terms.</p>
      </div>
    <% } %>
    <% employees.forEach(function(emp, i) { %>
      <a href="/employee/<%= emp.id %>" class="employee-card fade-up" style="animation-delay: <%= Math.min(i * 0.05, 0.5) %>s">
        <div class="card-top">
          <img src="<%= emp.avatar_url || 'https://ui-avatars.com/api/?background=6366f1&color=fff&name=' + encodeURIComponent(emp.full_name) %>" alt="<%= emp.full_name %>" class="avatar" loading="lazy">
          <span class="status-dot status-<%= emp.status %>" title="<%= emp.status %>"></span>
        </div>
        <h3 class="emp-name"><%= emp.full_name %></h3>
        <p class="emp-role"><%= emp.job_title || 'Team Member' %></p>
        <% if (emp.department_name) { %>
          <span class="dept-badge" style="--badge-color: <%= emp.department_color %>"><%= emp.department_name %></span>
        <% } %>
        <div class="card-footer">
          <span class="emp-location">📍 <%= emp.location || '—' %></span>
        </div>
      </a>
    <% }) %>
  </div>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <a class="page-link <%= p === safePage ? 'active' : '' %>"
           href="/?q=<%= encodeURIComponent(search) %>&department=<%= department %>&status=<%= status %>&sort=<%= sort %>&view=<%= view %>&page=<%= p %>"><%= p %></a>
      <% } %>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
</body>
</html>
