<% if (typeof success !== 'undefined' && success.length) { %>
  <% success.forEach(function(msg) { %>
    <div class="toast toast-success" data-autohide>
      <span class="toast-icon">✅</span><span><%= msg %></span>
      <button class="toast-close" aria-label="Dismiss">&times;</button>
    </div>
  <% }) %>
<% } %>
<% if (typeof error !== 'undefined' && error.length) { %>
  <% error.forEach(function(msg) { %>
    <div class="toast toast-error" data-autohide>
      <span class="toast-icon">⚠️</span><span><%= msg %></span>
      <button class="toast-close" aria-label="Dismiss">&times;</button>
    </div>
  <% }) %>
<% } %>
