<header class="topbar">
  <div class="container topbar-inner">
    <a href="/" class="brand">
      <span class="brand-icon">🧑‍💼</span>
      <span class="brand-text">Team<span class="accent">Base</span></span>
    </a>

    <nav class="main-nav">
      <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Directory</a>
      <a href="/admin/dashboard" class="nav-link">Admin Panel</a>
    </nav>

    <div class="topbar-actions">
      <div class="theme-switch" id="themeSwitch" title="Toggle theme">
        <button data-theme="light" class="theme-dot" aria-label="Light theme"></button>
        <button data-theme="dark" class="theme-dot" aria-label="Dark theme"></button>
        <button data-theme="ocean" class="theme-dot" aria-label="Ocean theme"></button>
        <button data-theme="sunset" class="theme-dot" aria-label="Sunset theme"></button>
      </div>
    </div>
  </div>
</header>
